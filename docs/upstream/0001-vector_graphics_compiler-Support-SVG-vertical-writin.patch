@@ -0,0 +1,128 @@
+// Copyright 2013 The Flutter Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+/// Layout support for SVG vertical writing modes (`writing-mode:
+/// vertical-rl` / `vertical-lr` / `tb` / `tb-rl`), used primarily by
+/// East Asian (CJK) text.
+///
+/// Flutter's paragraph builder has no vertical text layout, so vertical
+/// text is decomposed at compile time into per-cell horizontal text draws:
+/// upright characters are stacked along the block axis, characters whose
+/// vertical form is a rotation (brackets, dashes, the long sound mark) are
+/// rotated 90°, and full stops/commas are moved to the top-right corner of
+/// their cell. Runs of one or two ASCII alphanumerics stay upright
+/// (tate-chū-yoko); longer runs are rotated as a unit.
+///
+/// This is deliberately font-independent: it does not rely on the font
+/// providing Unicode vertical presentation forms (U+FE10..FE4F), which many
+/// fonts lack.
+library;
+
+/// Whether [value] (a raw `writing-mode` property value) selects a vertical
+/// writing mode.
+bool isVerticalWritingMode(String? value) {
+  if (value == null) {
+    return false;
+  }
+  return value.startsWith('vertical') || value.startsWith('tb');
+}
+
+// Characters whose vertical form is the horizontal glyph rotated 90°
+// (long sound mark, wave/em dashes, leaders, brackets, colon/semicolon).
+const Set<String> _rotatedChars = <String>{
+  'ー', '〜', '～', '−', '－', '＝', '…', '‥', '—', '–',
+  '「', '」', '『', '』', '(', ')', '（', '）',
+  '{', '}', '｛', '｝', '〔', '〕', '【', '】',
+  '《', '》', '〈', '〉', '[', ']', '［', '］',
+  '：', '；',
+};
+
+// Ideographic full stop / comma sit in the top-right corner of their cell
+// in vertical writing.
+const Set<String> _cornerChars = <String>{'、', '。', '，'};
+
+bool _isAsciiAlnum(int codeUnit) {
+  return (codeUnit >= 0x30 && codeUnit <= 0x39) ||
+      (codeUnit >= 0x41 && codeUnit <= 0x5A) ||
+      (codeUnit >= 0x61 && codeUnit <= 0x7A);
+}
+
+/// One cell of a vertical text column.
+class VerticalTextCell {
+  /// See [VerticalTextCell].
+  const VerticalTextCell(
+    this.text,
+    this.advance, {
+    this.rotated = false,
+    this.corner = false,
+  });
+
+  /// The text drawn in this cell, or null for a whitespace gap.
+  final String? text;
+
+  /// The block-axis advance of this cell in em units.
+  final double advance;
+
+  /// Whether the cell is drawn rotated 90° clockwise.
+  final bool rotated;
+
+  /// Whether the cell content is moved to the top-right corner
+  /// (ideographic full stop / comma).
+  final bool corner;
+}
+
+/// Splits [text] into vertical layout cells.
+List<VerticalTextCell> verticalTextCells(String text) {
+  final cells = <VerticalTextCell>[];
+  final List<String> chars = text.split('');
+  var i = 0;
+  while (i < chars.length) {
+    final String c = chars[i];
+    if (c == ' ' || c == '\t' || c == '\n' || c == '\r') {
+      cells.add(const VerticalTextCell(null, 0.5));
+      i++;
+    } else if (c == '　') {
+      cells.add(const VerticalTextCell(null, 1));
+      i++;
+    } else if (_isAsciiAlnum(c.codeUnitAt(0))) {
+      var j = i;
+      while (j < chars.length && _isAsciiAlnum(chars[j].codeUnitAt(0))) {
+        j++;
+      }
+      final String run = text.substring(i, j);
+      if (run.length <= 2) {
+        // Tate-chū-yoko: short alphanumeric runs stay upright in one cell.
+        cells.add(VerticalTextCell(run, 1));
+      } else {
+        cells.add(VerticalTextCell(run, 0.6 * run.length, rotated: true));
+      }
+      i = j;
+    } else if (_rotatedChars.contains(c)) {
+      cells.add(VerticalTextCell(c, 1, rotated: true));
+      i++;
+    } else if (_cornerChars.contains(c)) {
+      cells.add(VerticalTextCell(c, 1, corner: true));
+      i++;
+    } else {
+      cells.add(VerticalTextCell(c, 1));
+      i++;
+    }
+  }
+  return cells;
+}
+
+/// The alphabetic-baseline position of an upright cell, as a fraction of
+/// the font size from the cell top (typical CJK ascent).
+const double verticalCellBaseline = 0.88;
+
+/// Baseline correction for rotated cells so the glyph center coincides with
+/// the cell center after rotation.
+const double rotatedCellBaselineShift = 0.36;
+
+/// Offsets (x, y) of a corner cell's baseline from the cell's top-left, as
+/// fractions of the font size.
+const double cornerCellDx = 0.55;
+
+/// See [cornerCellDx].
+const double cornerCellDy = 0.38;
