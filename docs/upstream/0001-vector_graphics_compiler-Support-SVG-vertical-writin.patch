+  /// Resolves a text element in a vertical writing mode into a stack of
+  /// per-cell horizontal text draws (see `vertical_text.dart`).
+  ///
+  /// Flutter's paragraph layout has no vertical text support, so vertical
+  /// text is decomposed at compile time: upright glyphs are stacked along
+  /// the block axis, characters whose vertical form is a rotation are
+  /// rotated 90°, and ideographic full stops/commas move to the top-right
+  /// corner of their cell.
+  ///
+  /// Returns null when the subtree uses relative positioning (`dx`/`dy`),
+  /// which this pass does not support, so the caller can fall back to the
+  /// standard horizontal path.
+  Node? _resolveVerticalText(TextPositionNode textPositionNode, AffineMatrix data) {
+    final TextPosition position = textPositionNode.computeTextPosition(_bounds, data);
+    final double? x = position.x;
+    final double? y = position.y;
+    if (x == null || y == null) {
+      return null;
+    }
+
+    // Collect text runs in document order, grouped into columns. A nested
+    // text position element (`<tspan>`) with an absolute x and/or y starts
+    // a new column, matching the SVG semantics of absolute positioning.
+    final columns = <_VerticalTextColumn>[_VerticalTextColumn(x, y)];
+    var unsupported = false;
+    void collect(Node node) {
+      if (unsupported) {
+        return;
+      }
+      if (node is TextNode) {
+        columns.last.runs.add(node);
+      } else if (node is TextPositionNode) {
+        if (node.attributes.dx != null || node.attributes.dy != null) {
+          unsupported = true;
+          return;
+        }
+        if (node.attributes.x != null || node.attributes.y != null) {
+          columns.add(
+            _VerticalTextColumn(
+              node.attributes.x?.calculate(_bounds.width) ?? columns.last.x,
+              node.attributes.y?.calculate(_bounds.height) ?? columns.last.y,
+            ),
+          );
+        }
+        for (final Node child in node.children) {
+          collect(child is AttributedNode ? child.applyAttributes(node.attributes) : child);
+        }
+      } else {
+        unsupported = true;
+      }
+    }
+
+    for (final Node child in textPositionNode.children) {
+      collect(
+        child is AttributedNode ? child.applyAttributes(textPositionNode.attributes) : child,
+      );
+    }
+    if (unsupported || columns.every((_VerticalTextColumn c) => c.runs.isEmpty)) {
+      return null;
+    }
+
+    final children = <Node>[];
+    for (final column in columns) {
+      _resolveVerticalColumn(column, position.transform, data, children);
+    }
+    if (children.isEmpty) {
+      return Node.empty;
+    }
+    return ResolvedTextPositionNode(const TextPosition(reset: true), children);
+  }
+
+  void _resolveVerticalColumn(
+    _VerticalTextColumn column,
+    AffineMatrix? baseTransform,
+    AffineMatrix data,
+    List<Node> children,
+  ) {
+    if (column.runs.isEmpty) {
+      return;
+    }
+    final double x = column.x;
+    final runCells = <List<VerticalTextCell>>[
+      for (final TextNode run in column.runs) verticalTextCells(run.text),
+    ];
+    var totalExtent = 0.0;
+    for (var i = 0; i < column.runs.length; i++) {
+      final double fontSize = column.runs[i].attributes.fontSize ?? 16;
+      for (final VerticalTextCell cell in runCells[i]) {
+        totalExtent += cell.advance * fontSize;
+      }
+    }
+
+    final double anchorMultiplier = column.runs.first.attributes.textAnchorMultiplier ?? 0;
+    double cellTop = column.y - totalExtent * anchorMultiplier;
+
+    for (var i = 0; i < column.runs.length; i++) {
+      final TextNode run = column.runs[i];
+      final double fontSize = run.attributes.fontSize ?? 16;
+      final Paint? paint = run.computePaint(_bounds, data);
+      for (final VerticalTextCell cell in runCells[i]) {
+        final double extent = cell.advance * fontSize;
+        final String? cellText = cell.text;
+        if (cellText != null && cellText.trim().isNotEmpty && paint != null) {
+          var cellX = x;
+          final double baselineY;
+          var transform = baseTransform;
+          if (cell.rotated) {
+            final double centerY = cellTop + extent / 2;
+            baselineY = centerY + rotatedCellBaselineShift * fontSize;
+            final AffineMatrix rotation = AffineMatrix.identity
+                .translated(x, centerY)
+                .rotated(math.pi / 2)
+                .translated(-x, -centerY);
+            transform = transform == null ? rotation : transform.multiplied(rotation);
+          } else if (cell.corner) {
+            cellX = x + cornerCellDx * fontSize;
+            baselineY = cellTop + cornerCellDy * fontSize;
+          } else {
+            baselineY = cellTop + verticalCellBaseline * fontSize;
+          }
+          final config = TextConfig(
+            cellText,
+            0.5,
+            run.attributes.fontFamily,
+            run.attributes.fontWeight ?? normalFontWeight,
+            fontSize,
+            run.attributes.textDecoration ?? TextDecoration.none,
+            run.attributes.textDecorationStyle ?? TextDecorationStyle.solid,
+            run.attributes.textDecorationColor ?? Color.opaqueBlack,
+          );
+          children.add(
+            ResolvedTextPositionNode(
+              TextPosition(x: cellX, y: baselineY, reset: true, transform: transform),
+              <Node>[ResolvedTextNode(textConfig: config, paint: paint)],
+            ),
+          );
+        }
+        cellTop += extent;
+      }
+    }
+  }
+
