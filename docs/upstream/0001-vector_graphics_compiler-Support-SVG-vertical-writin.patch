+// Copyright 2013 The Flutter Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+import 'package:test/test.dart';
+import 'package:vector_graphics_compiler/vector_graphics_compiler.dart';
+
+void main() {
+  test('vertical writing-mode stacks characters along the block axis', () {
+    const svg = '''
+<svg xmlns="http://www.w3.org/2000/svg" width="200" height="100">
+<text x="100" y="20" font-size="10" writing-mode="vertical-rl">日本語</text>
+</svg>''';
+
+    final VectorInstructions instructions = parseWithoutOptimizers(svg);
+
+    expect(instructions.text.map((TextConfig t) => t.text), <String>['日', '本', '語']);
+    // Each cell is centered on the column axis.
+    expect(instructions.text.map((TextConfig t) => t.xAnchorMultiplier), everyElement(0.5));
+    final List<TextPosition> positions = instructions.textPositions
+        .where((TextPosition p) => p.x != null)
+        .toList();
+    expect(positions.map((TextPosition p) => p.x), everyElement(100));
+    // Baseline of each 1em cell sits at cellTop + 0.88em.
+    expect(positions.map((TextPosition p) => p.y), <double>[28.8, 38.8, 48.8]);
+  });
+
+  test('writing-mode via style and tb value also triggers vertical layout', () {
+    const svg = '''
+<svg xmlns="http://www.w3.org/2000/svg" width="200" height="100">
+<text x="10" y="10" font-size="10" style="writing-mode: tb;">縦書</text>
+</svg>''';
+
+    final VectorInstructions instructions = parseWithoutOptimizers(svg);
+    expect(instructions.text.map((TextConfig t) => t.text), <String>['縦', '書']);
+  });
+
+  test('rotated characters get a rotation transform', () {
+    const svg = '''
+<svg xmlns="http://www.w3.org/2000/svg" width="200" height="100">
+<text x="50" y="10" font-size="10" writing-mode="vertical-rl">あー</text>
+</svg>''';
+
+    final VectorInstructions instructions = parseWithoutOptimizers(svg);
+    expect(instructions.text.map((TextConfig t) => t.text), <String>['あ', 'ー']);
+    final List<TextPosition> positions = instructions.textPositions
+        .where((TextPosition p) => p.x != null)
+        .toList();
+    expect(positions[0].transform, isNull);
+    expect(positions[1].transform, isNotNull);
+  });
+
+  test('ideographic full stop moves to the top-right corner of its cell', () {
+    const svg = '''
+<svg xmlns="http://www.w3.org/2000/svg" width="200" height="100">
+<text x="50" y="10" font-size="10" writing-mode="vertical-rl">あ。</text>
+</svg>''';
+
+    final VectorInstructions instructions = parseWithoutOptimizers(svg);
+    final List<TextPosition> positions = instructions.textPositions
+        .where((TextPosition p) => p.x != null)
+        .toList();
+    expect(positions[0].x, 50);
+    expect(positions[1].x, 55.5); // 50 + 0.55em
+    expect(positions[1].y, closeTo(23.8, 0.001)); // cellTop 20 + 0.38em
+  });
+
+  test('short alphanumeric runs stay upright (tate-chu-yoko)', () {
+    const svg = '''
+<svg xmlns="http://www.w3.org/2000/svg" width="200" height="100">
+<text x="50" y="10" font-size="10" writing-mode="vertical-rl">第12回ABC</text>
+</svg>''';
+
+    final VectorInstructions instructions = parseWithoutOptimizers(svg);
+    expect(instructions.text.map((TextConfig t) => t.text), <String>['第', '12', '回', 'ABC']);
+    final List<TextPosition> positions = instructions.textPositions
+        .where((TextPosition p) => p.x != null)
+        .toList();
+    expect(positions[1].transform, isNull); // 12 upright in one cell
+    expect(positions[3].transform, isNotNull); // ABC rotated
+  });
+
+  test('text-anchor middle centers the column on the y coordinate', () {
+    const svg = '''
+<svg xmlns="http://www.w3.org/2000/svg" width="200" height="100">
+<text x="50" y="50" font-size="10" text-anchor="middle" writing-mode="vertical-rl">あい</text>
+</svg>''';
+
+    final VectorInstructions instructions = parseWithoutOptimizers(svg);
+    final List<TextPosition> positions = instructions.textPositions
+        .where((TextPosition p) => p.x != null)
+        .toList();
+    // Total extent 20; column top = 50 - 10 = 40.
+    expect(positions.map((TextPosition p) => p.y), <double>[48.8, 58.8]);
+  });
+
+  test('tspan attributes cascade into vertical cells', () {
+    const svg = '''
+<svg xmlns="http://www.w3.org/2000/svg" width="200" height="100">
+<text x="50" y="10" font-size="10" writing-mode="vertical-rl">あ<tspan font-size="20">い</tspan></text>
+</svg>''';
+
+    final VectorInstructions instructions = parseWithoutOptimizers(svg);
+    expect(instructions.text.map((TextConfig t) => t.text), <String>['あ', 'い']);
+    expect(instructions.text[0].fontSize, 10);
+    expect(instructions.text[1].fontSize, 20);
+    final List<TextPosition> positions = instructions.textPositions
+        .where((TextPosition p) => p.x != null)
+        .toList();
+    // Second cell starts after the first 1em (10px) cell.
+    expect(positions[1].y, closeTo(10 + 10 + 0.88 * 20, 0.001));
+  });
+
+  test('tspan with absolute position starts a new column', () {
+    const svg = '''
+<svg xmlns="http://www.w3.org/2000/svg" width="200" height="100">
+<text x="50" y="10" font-size="10" writing-mode="vertical-rl">あ<tspan x="30" y="20">い</tspan></text>
+</svg>''';
+
+    final VectorInstructions instructions = parseWithoutOptimizers(svg);
+    expect(instructions.text.map((TextConfig t) => t.text), <String>['あ', 'い']);
+    final List<TextPosition> positions = instructions.textPositions
+        .where((TextPosition p) => p.x != null)
+        .toList();
+    expect(positions[0].x, 50);
+    expect(positions[0].y, closeTo(18.8, 0.001)); // column 1 top = 10
+    expect(positions[1].x, 30);
+    expect(positions[1].y, closeTo(28.8, 0.001)); // column 2 top = 20
+  });
+
+  test('relative positioning (dx/dy) falls back to horizontal layout', () {
+    const svg = '''
+<svg xmlns="http://www.w3.org/2000/svg" width="200" height="100">
+<text x="50" y="10" writing-mode="vertical-rl">あ<tspan dx="5">い</tspan></text>
+</svg>''';
+
+    final VectorInstructions instructions = parseWithoutOptimizers(svg);
+    // Not decomposed: the runs stay whole.
+    expect(instructions.text.map((TextConfig t) => t.text), <String>['あ', 'い']);
+  });
+
+  test('horizontal text is unaffected', () {
+    const svg = '''
+<svg xmlns="http://www.w3.org/2000/svg" width="200" height="100">
+<text x="50" y="10" font-size="10">日本語</text>
+</svg>''';
+
+    final VectorInstructions instructions = parseWithoutOptimizers(svg);
+    expect(instructions.text.map((TextConfig t) => t.text), <String>['日本語']);
+  });
+}
